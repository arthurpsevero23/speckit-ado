{
  "ai": "copilot",
  "ai_commands_dir": null,
  "ai_skills": false,
  "branch_numbering": "sequential",
  "here": true,
  "offline": false,
  "preset": null,
  "script": "ps",
  "speckit_version": "0.6.11",
  "ado": {
    "enabled": true,
    "organization": "your-organization",
    "projectName": "your-project",
    "patTokenEnvVar": "ADO_PAT_TOKEN",
    "filterByState": ["Active", "Committed"],
    "filterByIteration": "",
    "specifySelection": {
      "enabled": true,
      "defaultTop": 50,
      "persistContextPath": ".specify/context/selected-pbi.json"
    },
    "creation": {
      "enabled": true,
      "workItemType": "Issue",
      "defaultState": "To Do",
      "defaultPriority": 3,
      "defaultTags": ["spec-kit-generated"],
      "persistContextPath": ".specify/context/created-pbi.json",
      "hierarchy": {
        "createHierarchy": false,
        "epicWorkItemType": "Epic",
        "epicState": "To Do",
        "storyWorkItemType": "Issue"
      }
    }
  }
}
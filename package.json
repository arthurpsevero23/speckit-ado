{
  "name": "@arthurpsevero23/spec-kit",
  "version": "0.5.2",
  "description": "AI-driven specification to task breakdown framework with Azure DevOps PBI integration and GitFlow branching support",
  "main": "index.js",
  "exports": {
    ".": "./index.js"
  },
  "bin": {
    "spec-kit": "bin/spec-kit.js"
  },
  "type": "module",
  "scripts": {
    "test": "node ./bin/spec-kit.js --help",
    "pack:dry": "npm pack --dry-run",
    "prepublishOnly": "node --input-type=module -e \"import {readFileSync} from 'node:fs'; const p=JSON.parse(readFileSync(new URL('./package.json',import.meta.url),'utf8')); console.log('Publishing '+p.name+' v'+p.version);\" && npm run lint && npm run test",
    "lint": "echo \"No lint configured yet\""
  },
  "files": [
    ".specify/docs/",
    ".specify/hooks/",
    ".specify/modules/",
    ".specify/scripts/",
    ".specify/templates/",
    ".specify/extensions.yml",
    ".specify/init-options.json",
    ".setup-spec-kit.ps1",
    "bin/",
    "index.js",
    "README.md"
  ],
  "keywords": [
    "spec-kit",
    "specification",
    "task-generation",
    "azure-devops",
    "pbi",
    "work-items",
    "gitflow",
    "branching",
    "ai-driven",
    "workflow"
  ],
  "author": "Arthur Severo <arthurpsevero@example.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arthurpsevero23/speckit-ado.git"
  },
  "bugs": {
    "url": "https://github.com/arthurpsevero23/speckit-ado/issues"
  },
  "homepage": "https://github.com/arthurpsevero23/speckit-ado#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "engines": {
    "node": ">=16.7.0"
  }
}
